      function syncPreviewFrames(version = Date.now()) {
        const selectedProject = state.projects[projectIndex];
        const selectedArticle = state.articles[articleIndex];
        const projectUrl = selectedProject?.slug ? `/project/${encodeURIComponent(selectedProject.slug)}` : '/projects';
        const articleUrl = selectedArticle?.slug ? `/articles/${encodeURIComponent(selectedArticle.slug)}` : '/';
        const projectPreview = qs('#projectPreview');
        const articlePreview = qs('#articlePreview');
        const projectLink = qs('#projectPreviewLink');
        const articleLink = qs('#articlePreviewLink');

        if (projectPreview) projectPreview.src = `${projectUrl}?preview=${version}`;
        if (articlePreview) articlePreview.src = `${articleUrl}?preview=${version}`;
        if (projectLink) projectLink.href = projectUrl;
        if (articleLink) articleLink.href = articleUrl;

        qsa('.front-preview').forEach((frame) => {
          if (frame.id !== 'projectPreview' && frame.id !== 'articlePreview') {
            frame.src = `/?preview=${version}`;
          }
        });
      }

      function scalePreviewFrames() {
        const canvasWidth = 1200;
        qsa('.preview-viewport').forEach((viewport) => {
          const frame = viewport.querySelector('.front-preview');
          if (!frame) return;
          const scale = Math.min(1, viewport.clientWidth / canvasWidth);
          frame.style.width = `${canvasWidth}px`;
          frame.style.minWidth = `${canvasWidth}px`;
          frame.style.height = `${Math.max(900, viewport.clientHeight / Math.max(scale, 0.1))}px`;
          frame.style.transform = `scale(${scale})`;
        });
      }

      const previewResizeObserver = 'ResizeObserver' in window
        ? new ResizeObserver(scalePreviewFrames)
        : null;

      qsa('.preview-viewport').forEach((viewport) => previewResizeObserver?.observe(viewport));
      window.addEventListener('resize', scalePreviewFrames);

      function field(name, label, value = '', options = {}) {
        const full = options.full ? ' full' : '';
        const tone = options.tone ? ` ${options.tone}` : '';
        const size = options.size ? ` ${options.size}` : '';
        const inputClass = options.content ? ' class="content-textarea"' : '';
        const placeholder = options.placeholder ? ` placeholder="${escapeHtml(options.placeholder)}"` : '';
        const hint = options.hint ? `<small>${escapeHtml(options.hint)}</small>` : '';
        const rows = options.rows ? ` rows="${escapeHtml(options.rows)}"` : '';
        const type = options.inputType || 'text';
        if (options.type === 'textarea') {
          return `<label class="field-card${full}${tone}${size}" data-field="${escapeHtml(name)}"><span class="field-top"><span>${escapeHtml(label)}</span>${hint}</span><textarea name="${escapeHtml(name)}"${inputClass}${placeholder}${rows}>${escapeHtml(value)}</textarea></label>`;
        }
        if (options.type === 'select') {
          return `<label class="field-card${full}${tone}${size}" data-field="${escapeHtml(name)}"><span class="field-top"><span>${escapeHtml(label)}</span>${hint}</span><select name="${escapeHtml(name)}">${options.choices.map((choice) => `<option value="${escapeHtml(choice.value)}" ${choice.value === value ? 'selected' : ''}>${escapeHtml(choice.label)}</option>`).join('')}</select></label>`;
        }
        return `<label class="field-card${full}${tone}${size}" data-field="${escapeHtml(name)}"><span class="field-top"><span>${escapeHtml(label)}</span>${hint}</span><input type="${escapeHtml(type)}" name="${escapeHtml(name)}" value="${escapeHtml(value)}"${placeholder} /></label>`;
      }

      function editorBlock(kicker, title, body, accent = '') {
        return `
          <section class="content-editor-block ${accent}">
            <div class="content-editor-head">
              <span>${escapeHtml(kicker)}</span>
              <h3>${escapeHtml(title)}</h3>
            </div>
            <div class="content-editor-grid">${body}</div>
          </section>
        `;
      }

      function settingControl(name, label, value = '', options = {}) {
        const placeholder = options.placeholder ? ` placeholder="${escapeHtml(options.placeholder)}"` : '';
        const tone = options.tone ? ` ${options.tone}` : '';
        const type = options.inputType || 'text';
        if (options.type === 'textarea') {
          return `
            <label class="setting-control${tone}" data-field="${escapeHtml(name)}">
              <span>${escapeHtml(label)}</span>
              <textarea name="${escapeHtml(name)}"${placeholder}>${escapeHtml(value)}</textarea>
            </label>
          `;
        }

        return `
          <label class="setting-control${tone}" data-field="${escapeHtml(name)}">
            <span>${escapeHtml(label)}</span>
            <input type="${escapeHtml(type)}" name="${escapeHtml(name)}" value="${escapeHtml(value)}"${placeholder} />
          </label>
        `;
      }


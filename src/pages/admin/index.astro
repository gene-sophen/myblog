---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthed } from '../../lib/auth';
import { getSettings } from '../../lib/content';

const settings = await getSettings();
const authed = isAuthed({ cookies: Astro.cookies });
---
<BaseLayout settings={settings} title={settings.adminTitle}>
  <section class="admin-container">
    <div class="section-head">
      <p class="eyebrow">Content Studio</p>
      <h1 class="page-title">{settings.adminTitle}</h1>
      <p class="page-intro">维护站点设置、项目生命周期、文章内容和文章详情页数据。</p>
    </div>

    {!authed ? (
      <form id="loginForm" class="glass-card admin-login">
        <label>
          管理密码
          <input name="password" type="password" placeholder="请输入 ADMIN_PASSWORD" required />
        </label>
        <button class="btn" type="submit">登录</button>
        <p id="loginMessage" class="muted"></p>
      </form>
    ) : (
      <div id="studio" class="admin-shell">
        <aside class="glass-card admin-sidebar">
          <button class="studio-tab active" data-tab="settings">站点设置</button>
          <button class="studio-tab" data-tab="projects">项目维护</button>
          <button class="studio-tab" data-tab="articles">文章维护</button>
          <button id="saveAll" class="btn" type="button">保存全部</button>
          <a class="btn secondary" href="/" target="_blank" rel="noreferrer">查看前台</a>
          <button id="logout" class="btn secondary" type="button">退出</button>
          <p id="saveMessage" class="muted"></p>
        </aside>

        <section class="glass-card admin-panel" data-panel="settings">
          <div class="panel-head studio-panel-head">
            <div>
              <p class="eyebrow">Site Profile</p>
              <h2 class="card-title">站点设置</h2>
              <p class="panel-desc">维护首页名片、站点标题、状态播报和联系方式。</p>
            </div>
          </div>
          <div class="admin-workbench">
            <div class="editor-surface">
              <form id="settingsForm" class="settings-board"></form>
            </div>
            <aside class="preview-surface">
              <div class="preview-head">
                <div>
                  <p class="eyebrow">Live Preview</p>
                  <h3>首页预览</h3>
                </div>
                <a class="btn secondary" href="/" target="_blank" rel="noreferrer">打开</a>
              </div>
              <div class="preview-viewport">
                <iframe class="front-preview" src="/?preview=settings" title="站点设置预览"></iframe>
              </div>
            </aside>
          </div>
        </section>

        <section class="glass-card admin-panel hidden" data-panel="projects">
          <div class="panel-head studio-panel-head">
            <div>
              <p class="eyebrow">Project Library</p>
              <h2 class="card-title">项目维护</h2>
              <p class="panel-desc">维护项目生命周期、进度、架构节点和首页展示状态。</p>
            </div>
            <button class="btn secondary" id="newProject" type="button">新增项目</button>
          </div>
          <div class="admin-workbench">
            <div class="editor-surface record-editor">
              <div id="projectList" class="record-list"></div>
              <form id="projectForm" class="admin-form"></form>
            </div>
            <aside class="preview-surface">
              <div class="preview-head">
                <div>
                  <p class="eyebrow">Project Preview</p>
                  <h3>前台项目页</h3>
                </div>
                <a class="btn secondary" id="projectPreviewLink" href="/projects" target="_blank" rel="noreferrer">打开</a>
              </div>
              <div class="preview-viewport">
                <iframe class="front-preview" id="projectPreview" src="/projects?preview=projects" title="项目预览"></iframe>
              </div>
            </aside>
          </div>
        </section>

        <section class="glass-card admin-panel hidden" data-panel="articles">
          <div class="panel-head studio-panel-head">
            <div>
              <p class="eyebrow">Writing Desk</p>
              <h2 class="card-title">文章维护</h2>
              <p class="panel-desc">维护说明书、开发日志、工具箱、面经和随笔正文。</p>
            </div>
            <button class="btn secondary" id="newArticle" type="button">新增文章</button>
          </div>
          <div class="admin-workbench">
            <div class="editor-surface record-editor">
              <div id="articleList" class="record-list"></div>
              <form id="articleForm" class="admin-form article-form"></form>
            </div>
            <aside class="preview-surface">
              <div class="preview-head">
                <div>
                  <p class="eyebrow">Article Preview</p>
                  <h3>文章页预览</h3>
                </div>
                <a class="btn secondary" id="articlePreviewLink" href="/" target="_blank" rel="noreferrer">打开</a>
              </div>
              <div class="preview-viewport">
                <iframe class="front-preview" id="articlePreview" src="/?preview=articles" title="文章预览"></iframe>
              </div>
            </aside>
          </div>
        </section>
      </div>
    )}
  </section>

  <style is:global>
    .admin-container {
      width: min(1760px, calc(100vw - 32px));
      margin: 0 auto;
    }

    .admin-container > .section-head {
      margin-bottom: 24px;
    }

    .admin-login {
      max-width: 520px;
      display: grid;
      gap: 18px;
      padding: 30px;
      background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.9), rgba(240, 249, 255, 0.82)),
        radial-gradient(circle at 10% 0%, rgba(90, 215, 242, 0.18), transparent 14rem);
    }

    .admin-shell {
      display: grid;
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 24px;
      align-items: start;
    }

    .admin-sidebar {
      position: sticky;
      top: 92px;
      display: grid;
      gap: 10px;
      padding: 18px;
      background:
        linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(240, 249, 255, 0.8)),
        radial-gradient(circle at 20% 0%, rgba(90, 215, 242, 0.22), transparent 12rem);
    }

    .studio-tab {
      min-height: 46px;
      border: 1px solid rgba(135, 196, 237, 0.2);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.68);
      color: var(--text-secondary);
      cursor: pointer;
      font-weight: 800;
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }

    .studio-tab:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-soft);
    }

    .studio-tab.active {
      color: white;
      border-color: transparent;
      background: linear-gradient(135deg, var(--sky-blue), var(--bright-cyan));
      box-shadow: var(--shadow-medium);
    }

    #saveMessage {
      min-height: 40px;
      padding: 8px 4px 0;
      font-size: 13px;
      line-height: 1.45;
    }

    .admin-panel {
      padding: 28px;
      min-height: 720px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(245, 255, 250, 0.78)),
        radial-gradient(circle at 100% 0%, rgba(112, 244, 191, 0.18), transparent 16rem);
    }

    .hidden {
      display: none !important;
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .studio-panel-head {
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(135, 196, 237, 0.14);
    }

    .panel-desc {
      margin: 5px 0 0;
      color: var(--text-tertiary);
      font-size: 14px;
    }

    .admin-workbench {
      display: grid;
      grid-template-columns: minmax(560px, 1fr) minmax(520px, 640px);
      gap: 22px;
      align-items: start;
    }

    .editor-surface,
    .preview-surface {
      min-width: 0;
      border: 1px solid rgba(255, 255, 255, 0.6);
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.62);
      box-shadow: 0 18px 48px rgba(90, 215, 242, 0.12);
      backdrop-filter: blur(14px);
    }

    .editor-surface {
      padding: 18px;
    }

    .preview-surface {
      position: sticky;
      top: 92px;
      padding: 16px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(240, 249, 255, 0.78)),
        radial-gradient(circle at 50% 0%, rgba(249, 248, 113, 0.16), transparent 12rem);
    }

    .preview-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .preview-head h3 {
      margin: 0;
      font-family: var(--font-display);
      font-size: 18px;
    }

    .preview-viewport {
      width: 100%;
      height: min(68vh, 720px);
      min-height: 520px;
      overflow: hidden;
      border: 1px solid rgba(135, 196, 237, 0.18);
      border-radius: 18px;
      background: white;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.4);
    }

    .front-preview {
      display: block;
      width: 1200px;
      min-width: 1200px;
      height: 1200px;
      border: 0;
      border-radius: 0;
      background: white;
      transform-origin: 0 0;
    }

    .record-editor {
      display: grid;
      grid-template-columns: minmax(220px, 260px) minmax(420px, 1fr);
      gap: 18px;
    }

    .record-list {
      max-height: 690px;
      display: grid;
      align-content: start;
      gap: 10px;
      overflow: auto;
      padding-right: 4px;
    }

    .record-item {
      border: 1px solid rgba(135, 196, 237, 0.18);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.72);
      padding: 13px 14px;
      color: var(--text-secondary);
      cursor: pointer;
      text-align: left;
      box-shadow: 0 8px 24px rgba(135, 196, 237, 0.08);
      transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }

    .record-item strong {
      display: block;
      margin-bottom: 2px;
      color: var(--text-primary);
      font-family: var(--font-display);
      font-size: 14px;
      line-height: 1.3;
    }

    .record-item span {
      color: var(--text-tertiary);
      font-family: var(--font-mono);
      font-size: 11px;
    }

    .record-item:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-soft);
    }

    .record-item.active {
      color: white;
      border-color: transparent;
      background: linear-gradient(135deg, var(--sky-blue), var(--bright-cyan));
      box-shadow: var(--shadow-medium);
    }

    .record-item.active strong,
    .record-item.active span {
      color: white;
    }

    .admin-form {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 15px;
      min-width: 0;
    }

    .settings-board {
      display: grid;
      gap: 18px;
    }

    .admin-form label {
      display: grid;
      gap: 8px;
      padding: 12px;
      color: var(--text-secondary);
      border: 1px solid rgba(135, 196, 237, 0.12);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.48);
      font-size: 12px;
      font-weight: 800;
    }

    .field-card {
      position: relative;
      overflow: hidden;
      display: grid;
      align-content: start;
      gap: 10px;
      min-height: 118px;
      padding: 14px;
      color: var(--text-secondary);
      border: 1px solid rgba(135, 196, 237, 0.13);
      border-radius: 18px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(240, 249, 255, 0.5)),
        radial-gradient(circle at 100% 0%, rgba(90, 215, 242, 0.1), transparent 10rem);
      font-size: 12px;
      font-weight: 800;
      box-shadow: 0 12px 34px rgba(135, 196, 237, 0.08);
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .field-card::after {
      content: "";
      position: absolute;
      right: -36px;
      bottom: -42px;
      width: 110px;
      height: 110px;
      opacity: 0.16;
      background: var(--gradient-cool);
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
      pointer-events: none;
    }

    .field-card:focus-within {
      transform: translateY(-2px);
      border-color: rgba(90, 215, 242, 0.45);
      box-shadow: 0 18px 44px rgba(90, 215, 242, 0.16);
    }

    .field-card.primary-field {
      background:
        linear-gradient(135deg, rgba(135, 196, 237, 0.2), rgba(255, 255, 255, 0.7)),
        radial-gradient(circle at 100% 0%, rgba(68, 232, 226, 0.16), transparent 14rem);
      border-color: rgba(90, 215, 242, 0.28);
    }

    .field-card.title-field {
      min-height: 144px;
      grid-column: span 2;
    }

    .field-card.title-field input {
      min-height: 58px;
      font-family: var(--font-display);
      font-size: clamp(26px, 4vw, 38px);
      font-weight: 900;
      line-height: 1;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(240, 249, 255, 0.78));
    }

    .field-card.subtitle-field input,
    .field-card.identity-field input {
      min-height: 48px;
      border-radius: 999px;
      color: var(--deep-blue);
      font-weight: 800;
      background: rgba(135, 196, 237, 0.12);
    }

    .field-card.avatar-field {
      min-height: 144px;
      justify-items: center;
      text-align: center;
      background:
        radial-gradient(circle at 50% 20%, rgba(90, 215, 242, 0.24), transparent 8rem),
        rgba(255, 255, 255, 0.68);
    }

    .field-card.avatar-field .field-top {
      width: 100%;
    }

    .field-card.avatar-field input {
      width: 92px;
      height: 92px;
      padding: 0;
      color: white;
      text-align: center;
      background: var(--gradient-cool);
      border: 0;
      border-radius: 45% 55% 50% 50% / 50% 45% 55% 50%;
      box-shadow: var(--shadow-glow);
      font-family: var(--font-display);
      font-size: 40px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .field-card.name-field input {
      min-height: 52px;
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
    }

    .field-card.bio-field textarea {
      min-height: 190px;
      font-size: 15px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(245, 255, 250, 0.72));
    }

    .field-card.live-field {
      min-height: 132px;
      background:
        linear-gradient(135deg, rgba(112, 244, 191, 0.14), rgba(249, 248, 113, 0.1)),
        rgba(255, 255, 255, 0.58);
      border-color: rgba(112, 244, 191, 0.28);
    }

    .field-card.live-field::before {
      content: "";
      position: absolute;
      left: 16px;
      bottom: 18px;
      width: 10px;
      height: 10px;
      background: var(--mint);
      border-radius: 999px;
      box-shadow: 0 0 14px var(--mint);
      z-index: 1;
    }

    .field-card.live-field textarea {
      min-height: 82px;
      padding-left: 36px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.76);
      line-height: 1.45;
    }

    .field-card.link-field input,
    .field-card.mail-field input,
    .field-card.location-field input,
    .field-card.studio-field input {
      min-height: 48px;
      border-radius: 999px;
      font-family: var(--font-mono);
      font-size: 13px;
    }

    .field-card.link-field input {
      color: var(--deep-blue);
    }

    .field-card.mail-field input {
      color: #2d8a5e;
    }

    .field-card.full,
    .admin-form label.full {
      grid-column: 1 / -1;
    }

    .field-top {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 10px;
      min-height: 18px;
      position: relative;
      z-index: 1;
    }

    .field-top > span:nth-child(2) {
      flex: 1;
      min-width: 0;
    }

    .admin-form input,
    .admin-form select,
    .admin-form textarea,
    .admin-login input,
    .field-card input,
    .field-card select,
    .field-card textarea {
      width: 100%;
      min-width: 0;
      border: 1px solid rgba(135, 196, 237, 0.28);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.82);
      color: var(--text-primary);
      padding: 12px 13px;
      outline: none;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      position: relative;
      z-index: 1;
    }

    .admin-form input:focus,
    .admin-form select:focus,
    .admin-form textarea:focus,
    .admin-login input:focus,
    .field-card input:focus,
    .field-card select:focus,
    .field-card textarea:focus {
      border-color: var(--bright-cyan);
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 0 0 4px rgba(90, 215, 242, 0.15);
    }

    .admin-form textarea,
    .field-card textarea {
      min-height: 110px;
      resize: vertical;
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.65;
    }

    .settings-board textarea {
      min-height: 132px;
    }

    .settings-board .live-field textarea {
      min-height: 86px;
    }

    .settings-board input::placeholder,
    .settings-board textarea::placeholder {
      color: rgba(100, 116, 139, 0.58);
    }

    .admin-form .content-textarea {
      min-height: 420px;
    }

    .article-form {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .form-actions {
      grid-column: 1 / -1;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      padding-top: 4px;
    }

    @media (max-width: 1440px) {
      .admin-workbench {
        grid-template-columns: minmax(0, 1fr);
      }

      .preview-surface {
        position: static;
      }

      .preview-viewport {
        height: 560px;
      }
    }

    @media (max-width: 1100px) {
      .admin-shell,
      .record-editor,
      .admin-form {
        grid-template-columns: 1fr;
      }

      .admin-sidebar {
        position: static;
      }

      .admin-panel {
        padding: 20px;
      }
    }

    /* Calm settings editor: clean CodePulse controls without visual clutter. */
    .settings-board {
      gap: 16px;
    }

    .field-card::after {
      display: none !important;
    }

    .field-card,
    .field-card.primary-field,
    .field-card.live-field,
    .field-card.avatar-field {
      min-height: auto;
      justify-items: stretch;
      padding: 12px;
      text-align: left;
      border-color: rgba(135, 196, 237, 0.16);
      border-radius: 16px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(255, 255, 255, 0.54));
      box-shadow: 0 8px 22px rgba(135, 196, 237, 0.07);
    }

    .field-card:focus-within {
      transform: translateY(-1px);
      border-color: rgba(90, 215, 242, 0.42);
      box-shadow: 0 12px 30px rgba(90, 215, 242, 0.14);
    }

    .field-card.title-field {
      grid-column: 1 / -1;
      min-height: auto;
    }

    .field-card.full {
      grid-column: 1 / -1;
    }

    .field-top {
      min-height: auto;
      margin-bottom: 2px;
      color: var(--text-tertiary);
      font-size: 12px;
      letter-spacing: 0;
    }

    .field-top > span:nth-child(2),
    .field-top > span:first-child {
      flex: initial;
    }

    .field-card input,
    .field-card select,
    .field-card textarea,
    .field-card.title-field input,
    .field-card.name-field input,
    .field-card.subtitle-field input,
    .field-card.identity-field input,
    .field-card.avatar-field input,
    .field-card.link-field input,
    .field-card.mail-field input,
    .field-card.location-field input,
    .field-card.studio-field input {
      width: 100%;
      height: auto;
      min-height: 44px;
      padding: 10px 12px;
      color: var(--text-primary);
      border: 1px solid rgba(135, 196, 237, 0.24);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.82);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.68);
      font-family: var(--font-body);
      font-size: 15px;
      font-weight: 600;
      text-align: left;
      text-transform: none;
    }

    .field-card.title-field input {
      min-height: 52px;
      font-family: var(--font-display);
      font-size: clamp(24px, 3vw, 32px);
      font-weight: 850;
      background:
        linear-gradient(135deg, rgba(135, 196, 237, 0.14), rgba(255, 255, 255, 0.88));
    }

    .field-card.avatar-field input {
      max-width: 120px;
      color: white;
      text-align: center;
      background: var(--gradient-cool);
      border: 0;
      border-radius: 18px;
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 900;
    }

    .field-card.bio-field textarea {
      min-height: 150px;
    }

    .field-card.live-field textarea {
      min-height: 76px;
      padding-left: 34px;
      border-radius: 18px;
      line-height: 1.55;
    }

    .field-card.live-field::before {
      left: 24px;
      bottom: 28px;
    }

    /* Componentized site settings editor */
    #settingsForm.settings-board {
      display: grid;
      gap: 18px;
    }

    .settings-hero-editor,
    .settings-content-editor,
    .settings-contact-editor {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(135, 196, 237, 0.18);
      border-radius: 24px;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.86), rgba(240, 249, 255, 0.58)),
        radial-gradient(circle at 100% 0%, rgba(90, 215, 242, 0.13), transparent 15rem);
      box-shadow: 0 18px 46px rgba(135, 196, 237, 0.11);
    }

    .settings-hero-editor {
      display: grid;
      grid-template-columns: 150px minmax(0, 1fr);
      gap: 18px;
      padding: 18px;
      align-items: stretch;
    }

    .hero-avatar-editor {
      display: grid;
      justify-items: center;
      align-content: center;
      gap: 12px;
      min-height: 178px;
      padding: 16px;
      border: 1px solid rgba(90, 215, 242, 0.22);
      border-radius: 22px;
      background:

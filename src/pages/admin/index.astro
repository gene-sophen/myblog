      function insertIntoArticleContent(text) {
        const textarea = qs('#articleForm textarea[name="content"]');
        if (!textarea) return;
        textarea.classList.remove('hidden');
        qs('#markdownPreview')?.classList.remove('active');
        const start = textarea.selectionStart ?? textarea.value.length;
        const end = textarea.selectionEnd ?? textarea.value.length;
        textarea.value = `${textarea.value.slice(0, start)}${text}${textarea.value.slice(end)}`;
        textarea.focus();
        textarea.selectionStart = textarea.selectionEnd = start + text.length;
        setDirty(true);
      }

      function setDirty(value = true) {
        isDirty = value;
        const message = qs('#saveMessage');
        if (message && value) message.textContent = '有未保存更改。';
      }

      studio.addEventListener('input', () => setDirty(true));
      studio.addEventListener('change', () => setDirty(true));
      window.addEventListener('beforeunload', (event) => {
        if (!isDirty) return;
        event.preventDefault();
        event.returnValue = '';

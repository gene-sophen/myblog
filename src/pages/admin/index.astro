        qs('#saveMessage').textContent = '正在上传图片...';
        try {
          const response = await fetch('/api/admin/upload-image', { method: 'POST', body: formData });
          const result = await response.json().catch(() => ({}));
          if (!response.ok) {
            qs('#saveMessage').textContent = result.error || '图片上传失败。';
            return;
          }
          insertIntoArticleContent(`\n![${file.name.replace(/\.[^.]+$/, '')}](${result.path})\n`);
          qs('#saveMessage').textContent = '图片已上传，并插入正文。';

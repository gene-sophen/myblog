        tool: '工具箱',
        interview: '面经实录',
        job: '求职心路',
        resume: '简历经验',
        essay: '随笔'
      };
      const articleTemplates = {
        devlog: '## 背景\\n\\n这次改动从什么问题开始？\\n\\n## 实现\\n\\n核心实现路径、关键取舍和遇到的坑。\\n\\n## 结果\\n\\n现在完成了什么，还剩什么。\\n\\n## 下一步\\n\\n接下来准备继续推进的事项。\\n',
        spec: '## 目标\\n\\n这个项目要解决什么问题？\\n\\n## 内容模型\\n\\n- 核心实体\\n- 页面入口\\n- 数据流向\\n\\n## 技术方案\\n\\n为什么这样设计？\\n\\n## 维护方式\\n\\n如何持续更新和部署。\\n',
        tool: '## 适用场景\\n\\n什么时候会用到这个工具？\\n\\n## 使用方式\\n\\n```bash\\n# command here\\n```\\n\\n## 注意事项\\n\\n容易踩坑的地方。\\n',
        interview: '## 提问内容\\n\\n- 问题一\\n- 问题二\\n\\n## 回答思路\\n\\n先说结论，再补原理，最后给工程实践。\\n\\n## 事后反思\\n\\n哪些地方答得好，哪些地方需要补。\\n',
        essay: '## 记录\\n\\n这个月最值得记录的一件事。\\n\\n## 变化\\n\\n我做出了什么调整？\\n\\n## 复盘\\n\\n下个月要继续坚持或修正什么。\\n'
      };
      const escapeHtml = (value) => String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
      const progressFromText = (value) => lines(value).map((row) => {
        const [label, rawValue] = row.split(':');
        const nextValue = Math.min(100, Math.max(0, Number(rawValue || 0) || 0));
        return { label: (label || '').trim(), value: nextValue };
      }).filter((item) => item.label);
      const progressToText = (items) => (items || []).map((item) => `${item.label}:${item.value}`).join('\n');
      const today = () => new Date().toISOString().slice(0, 10);

      function parseFrontmatterScalar(value) {
        const next = String(value || '').trim();
        if (next === 'true') return true;
        if (next === 'false') return false;
        if (/^-?\d+(\.\d+)?$/.test(next)) return Number(next);
        if ((next.startsWith('"') && next.endsWith('"')) || (next.startsWith("'") && next.endsWith("'"))) {
          try {
            return JSON.parse(next);
          } catch {
            return next.slice(1, -1);
          }
        }
        return next;
      }

      function parseFrontmatter(markdown) {
        const source = String(markdown || '').replace(/\r\n/g, '\n').replace(/^\uFEFF/, '').trimStart();
        if (!source.startsWith('---\n')) return { data: {}, body: source.trimStart(), hasFrontmatter: false };
        const closingMatch = source.slice(4).match(/\n---[ \t]*(?:\n|$)/);
        if (!closingMatch || closingMatch.index === undefined) return { data: {}, body: source.trimStart(), hasFrontmatter: false };

        const data = {};
        const closingIndex = 4 + closingMatch.index;
        const closingEnd = closingIndex + closingMatch[0].length;
        const frontmatter = source.slice(4, closingIndex).trim();
        const body = source.slice(closingEnd).replace(/^\n/, '');
        const rows = frontmatter.split('\n');
        for (let index = 0; index < rows.length; index += 1) {
          const row = rows[index];
          if (!row.trim() || row.trimStart().startsWith('#') || row.startsWith(' ') || row.startsWith('\t')) continue;
          const match = row.match(/^([A-Za-z][\w-]*):(?:\s*(.*))?$/);
          if (!match) continue;
          const key = match[1];
          const rawValue = match[2] || '';
          if (rawValue.trim()) {
            data[key] = parseFrontmatterScalar(rawValue);
            continue;
          }
          const items = [];
          while (index + 1 < rows.length && /^\s+-\s+/.test(rows[index + 1])) {
            index += 1;
            items.push(String(parseFrontmatterScalar(rows[index].replace(/^\s+-\s+/, ''))));
          }
          data[key] = items;
        }
        return { data, body, hasFrontmatter: true };
      }

      function valueAsString(value) {
        return typeof value === 'string' ? value : value === undefined || value === null ? '' : String(value);
      }

      function valueAsList(value) {
        return Array.isArray(value) ? value.map(String).filter(Boolean) : [];
      }

      function slugify(value) {
        return String(value || '')
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      function parseArticleMarkdown(markdown, fileName = '') {
        const { data, body, hasFrontmatter } = parseFrontmatter(markdown);
        const fileSlug = slugify(fileName.replace(/\.[^.]+$/, ''));
        const kind = articleKinds.includes(valueAsString(data.kind)) ? valueAsString(data.kind) : 'devlog';
        const slug = valueAsString(data.slug) || fileSlug || slugify(data.title) || `imported-${Date.now()}`;
        const article = {
          slug,
          title: valueAsString(data.title),
          date: valueAsString(data.date) || today(),
          kind,
          category: valueAsString(data.category) || articleKindDefaults[kind],
          projectSlug: valueAsString(data.projectSlug),
          lifecycle: valueAsString(data.lifecycle),
        tags: valueAsList(data.tags),
          status: articleStatuses.includes(valueAsString(data.status)) ? valueAsString(data.status) : 'draft',
          company: valueAsString(data.company),
          position: valueAsString(data.position),
          excerpt: valueAsString(data.excerpt),
          content: body.trim()
        };
        return { article, hasFrontmatter };
      }

      function validateImportedArticle(article, hasFrontmatter) {
        const errors = [];
        if (!hasFrontmatter) errors.push('文件需要包含 frontmatter，格式以 --- 开始和结束。');
        if (!article.title) errors.push('frontmatter.title 不能为空。');
        if (!slugPattern.test(article.slug)) errors.push('slug 只能使用小写字母、数字和短横线。');
        if (!/^\d{4}-\d{2}-\d{2}$/.test(article.date) || Number.isNaN(Date.parse(`${article.date}T00:00:00.000Z`))) {
          errors.push('date 必须是 YYYY-MM-DD 格式。');
        }
        if (!articleKinds.includes(article.kind)) errors.push('kind 必须是 spec、devlog、tool、interview、job、resume 或 essay。');
        if (!articleStatuses.includes(article.status)) errors.push('status 必须是 draft 或 published。');
        if (article.projectSlug && !slugPattern.test(article.projectSlug)) errors.push('projectSlug 只能使用小写字母、数字和短横线。');
        if (article.lifecycle && !['ongoing', 'archived'].includes(article.lifecycle)) errors.push('lifecycle 只能是 ongoing、archived 或留空。');
        if (!article.content) errors.push('正文不能为空。');
        return errors;
      }

      function makeUniqueArticleSlug(slug) {
        const taken = new Set(state.articles.map((article) => article.slug));
        let next = slugPattern.test(slug) ? slug : 'imported-article';
        let counter = 2;
        while (taken.has(next)) {
          next = `${slug}-${counter}`;
          counter += 1;
        }
        return next;
      }

      function renderArticleImportPanel() {
        const panel = qs('#articleImportPanel');
        if (!panel) return;
        if (!articleImportDraft) {
          panel.classList.add('hidden');
          panel.innerHTML = '';
          return;
        }

        const { article, errors, fileName, existingIndex } = articleImportDraft;
        const hasConflict = existingIndex >= 0;
        panel.classList.remove('hidden');
        panel.innerHTML = `
          <div class="import-panel-head">
            <div>
              <p class="eyebrow">Markdown Import</p>
              <h3>${escapeHtml(fileName)}</h3>
            </div>
            <button class="btn secondary" id="cancelArticleImport" type="button">取消</button>
          </div>
          ${errors.length ? `<div class="import-errors">${errors.map((error) => `<div>${escapeHtml(error)}</div>`).join('')}</div>` : ''}
          ${hasConflict ? `<div class="import-warning">已存在 slug 为 ${escapeHtml(article.slug)} 的文章。请选择覆盖已有文章，或另存为新文章。</div>` : ''}
          <div class="import-grid">
            <div class="import-field"><span>标题</span><strong>${escapeHtml(article.title || '未填写')}</strong></div>
            <div class="import-field"><span>Slug</span><strong>${escapeHtml(article.slug)}</strong></div>
            <div class="import-field"><span>日期</span><strong>${escapeHtml(article.date)}</strong></div>
            <div class="import-field"><span>类型</span><strong>${escapeHtml(article.kind)}</strong></div>
            <div class="import-field"><span>分类</span><strong>${escapeHtml(article.category || '未填写')}</strong></div>
            <div class="import-field"><span>标签</span><strong>${escapeHtml((article.tags || []).join(', ') || '无')}</strong></div>
          </div>
          <pre class="import-body-preview">${escapeHtml(article.content.slice(0, 1200) || '正文为空')}</pre>
          ${hasConflict ? `
            <div class="import-options">
              <label><input type="radio" name="articleImportMode" value="replace" ${articleImportDraft.mode === 'replace' ? 'checked' : ''} />覆盖已有文章</label>
              <label><input type="radio" name="articleImportMode" value="new" ${articleImportDraft.mode === 'new' ? 'checked' : ''} />另存为新文章</label>
            </div>
          ` : ''}
          <div class="form-actions">
            <button class="btn" id="confirmArticleImport" type="button" ${errors.length ? 'disabled' : ''}>确认导入</button>
          </div>
        `;

        qs('#cancelArticleImport')?.addEventListener('click', () => {
          articleImportDraft = null;
          renderArticleImportPanel();
        });
        qsa('input[name="articleImportMode"]').forEach((input) => input.addEventListener('change', () => {
          articleImportDraft.mode = input.value;
        }));
        qs('#confirmArticleImport')?.addEventListener('click', confirmArticleImport);
      }

      function confirmArticleImport() {
        if (!articleImportDraft || articleImportDraft.errors.length) return;
        readArticleForm();
        const imported = { ...articleImportDraft.article, tags: [...articleImportDraft.article.tags] };
        if (articleImportDraft.existingIndex >= 0 && articleImportDraft.mode === 'replace') {
          state.articles[articleImportDraft.existingIndex] = imported;
          articleIndex = articleImportDraft.existingIndex;
        } else {
          imported.slug = makeUniqueArticleSlug(imported.slug);
          state.articles.unshift(imported);
          articleIndex = 0;
        }
        articleImportDraft = null;
        setDirty(true);
        renderArticles();
        qs('#saveMessage').textContent = '已导入到编辑列表，点击“保存全部”后写入 Markdown 文件。';
      }

      function downloadTemplate() {
        const template = `---\nslug: \"my-devlog\"\ntitle: \"一次开发日志\"\ndate: \"${today()}\"\nstatus: \"draft\"\nkind: \"devlog\"\ncategory: \"开发日志\"\nprojectSlug: \"codepulse-blog\"\nlifecycle: \"ongoing\"\ntags:\n  - \"Astro\"\n  - \"Markdown\"\ncompany: \"\"\nposition: \"\"\nexcerpt: \"这里写文章摘要。\"\n---\n\n## 背景\n\n这里开始写正文。\n`;
        const url = URL.createObjectURL(new Blob([template], { type: 'text/markdown;charset=utf-8' }));
        const link = document.createElement('a');
        link.href = url;
        link.download = `article-template-${today()}.md`;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      function quoteYaml(value) {
        return JSON.stringify(String(value ?? ''));
      }

      function stringifyFrontmatter(data) {
        const rows = ['---'];
        Object.entries(data).forEach(([key, value]) => {
          if (Array.isArray(value)) {
            rows.push(`${key}:`);
            value.forEach((item) => rows.push(`  - ${quoteYaml(item)}`));
          } else if (typeof value === 'boolean' || typeof value === 'number') {
            rows.push(`${key}: ${value}`);
          } else {
            rows.push(`${key}: ${quoteYaml(value)}`);
          }
        });
        rows.push('---');
        return `${rows.join('\n')}\n\n`;
      }

      function articleToMarkdown(article) {
        return `${stringifyFrontmatter({
          slug: article.slug,
          title: article.title,
          date: article.date,
          status: article.status || 'draft',
          kind: article.kind,
          category: article.category,
          projectSlug: article.projectSlug || '',
          lifecycle: article.lifecycle || '',
          tags: article.tags || [],
          company: article.company || '',
          position: article.position || '',
          excerpt: article.excerpt || ''
        })}${String(article.content || '').trim()}\n`;
      }

      function markdownList(items) {
        return items?.length ? items.map((item) => `- ${item}`).join('\n') : '- ';
      }

      function projectToMarkdown(project) {
        return `${stringifyFrontmatter({
          slug: project.slug,
          name: project.name,
          status: project.status,
          statusLabel: project.statusLabel,
          tech: project.tech || [],
          progress: (project.progress || []).map((item) => `${item.label}:${item.value}`),
          releaseNote: project.releaseNote || '',
          featured: Boolean(project.featured)
        })}## 项目简介\n\n${project.summary || ''}\n\n## 近期进展\n\n${project.monthUpdate || ''}\n\n## 架构流程\n\n${markdownList(project.architecture || [])}\n`;
      }

      function settingsToMarkdown(settings) {
        return `${stringifyFrontmatter({
          siteTitle: settings.siteTitle,
          siteSubtitle: settings.siteSubtitle,
          ownerName: settings.ownerName,
          ownerInitial: settings.ownerInitial,
          identity: settings.identity,
          github: settings.github,
          email: settings.email,
          location: settings.location,
          adminTitle: settings.adminTitle
        })}## 博客简介\n\n${settings.bio || ''}\n\n## 状态播报\n\n${settings.status || ''}\n`;
      }

      function extractSection(body, heading) {
        const source = String(body || '').replace(/\r\n/g, '\n');
        const escaped = heading.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const match = source.match(new RegExp(`^##\\s+${escaped}\\s*$`, 'm'));
        if (!match || match.index === undefined) return '';
        const rest = source.slice(match.index + match[0].length).replace(/^\n+/, '');
        const nextHeading = rest.search(/^##\s+/m);
        return (nextHeading === -1 ? rest : rest.slice(0, nextHeading)).trim();
      }

      function listFromSection(body, heading) {
        return extractSection(body, heading).split('\n').map((line) => line.trim().replace(/^-\s+/, '')).filter(Boolean);
      }

      function parseSettingsMarkdown(markdown) {
        const { data, body, hasFrontmatter } = parseFrontmatter(markdown);
        if (!hasFrontmatter) throw new Error('设置文件需要 frontmatter。');
        return {
          siteTitle: valueAsString(data.siteTitle),
          siteSubtitle: valueAsString(data.siteSubtitle),
          ownerName: valueAsString(data.ownerName),
          ownerInitial: valueAsString(data.ownerInitial),
          identity: valueAsString(data.identity),
          github: valueAsString(data.github),
          email: valueAsString(data.email),
          location: valueAsString(data.location),
          adminTitle: valueAsString(data.adminTitle),
          bio: extractSection(body, '博客简介') || valueAsString(data.bio),
          status: extractSection(body, '状态播报') || valueAsString(data.status)
        };
      }

      function parseProjectMarkdown(markdown, fileName = '') {
        const { data, body, hasFrontmatter } = parseFrontmatter(markdown);
        if (!hasFrontmatter) throw new Error('项目文件需要 frontmatter。');
        return {
          slug: valueAsString(data.slug) || slugify(fileName.replace(/\.[^.]+$/, '')),
          name: valueAsString(data.name),
          status: valueAsString(data.status) || 'ongoing',
          statusLabel: valueAsString(data.statusLabel),
          tech: valueAsList(data.tech),
          progress: progressFromText(valueAsList(data.progress).join('\n')),
          summary: extractSection(body, '项目简介'),
          monthUpdate: extractSection(body, '近期进展'),
          releaseNote: valueAsString(data.releaseNote),
          architecture: listFromSection(body, '架构流程'),
          featured: data.featured === true || data.featured === 'true'
        };
      }

      function downloadText(fileName, body) {
        const url = URL.createObjectURL(new Blob([body], { type: 'text/markdown;charset=utf-8' }));
        const link = document.createElement('a');
        link.href = url;
        link.download = fileName;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      function inlineMarkdownPreview(value) {
        return escapeHtml(value)
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
          .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noreferrer">$1</a>');
      }

      function tableCellsPreview(row) {
        const cells = [];
        let value = '';
        let escaped = false;
        let source = String(row || '').trim();
        if (source.startsWith('|')) source = source.slice(1);
        if (source.endsWith('|')) source = source.slice(0, -1);
        for (const character of source) {
          if (escaped) {
            value += character;
            escaped = false;
          } else if (character === '\\') {
            escaped = true;
          } else if (character === '|') {
            cells.push(value.trim());
            value = '';
          } else {
            value += character;
          }
        }
        if (escaped) value += '\\';
        cells.push(value.trim());
        return cells;
      }

      function tableAlignmentsPreview(row) {
        const cells = tableCellsPreview(row);
        if (!cells.length || !cells.every((cell) => /^:?-{3,}:?$/.test(cell))) return null;
        return cells.map((cell) => {
          const left = cell.startsWith(':');
          const right = cell.endsWith(':');
          if (left && right) return 'center';
          if (right) return 'right';
          return 'left';
        });
      }

      function renderMarkdownPreview(markdown = '') {
        const rows = String(markdown || '').replace(/\r\n/g, '\n').split('\n');
        const html = [];
        let inList = false;
        let inCode = false;
        const codeRows = [];
        let table = null;
        const closeList = () => {
          if (inList) {
            html.push('</ul>');
            inList = false;
          }
        };
        const closeTable = () => {
          if (!table) return;
          const [header, ...body] = table.rows;
          const renderRow = (cells, tag) => cells
            .map((cell, index) => `<${tag} style="text-align:${table.alignments[index] || 'left'}">${inlineMarkdownPreview(cell)}</${tag}>`)
            .join('');
          html.push(`<div class="table-wrap"><table><thead><tr>${renderRow(header, 'th')}</tr></thead><tbody>${body.map((row) => `<tr>${renderRow(row, 'td')}</tr>`).join('')}</tbody></table></div>`);
          table = null;
        };
        for (let index = 0; index < rows.length; index += 1) {
          const row = rows[index];
          if (row.trim().startsWith('```')) {
            if (inCode) {
              html.push(`<pre><code>${escapeHtml(codeRows.join('\n'))}</code></pre>`);
              codeRows.length = 0;
              inCode = false;
            } else {
              closeList();
              closeTable();
              inCode = true;
            }
            continue;
          }
          if (inCode) {
            codeRows.push(row);
            continue;
          }
          if (table) {
            if (row.includes('|')) {
              table.rows.push(tableCellsPreview(row));
              continue;
            }
            closeTable();
          }
          const alignments = rows[index + 1] ? tableAlignmentsPreview(rows[index + 1]) : null;
          if (row.includes('|') && alignments) {
            closeList();
            table = { alignments, rows: [tableCellsPreview(row)] };
            index += 1;
            continue;
          }
          if (!row.trim()) {
            closeList();
            continue;
          }
          if (row.startsWith('### ')) {
            closeList();
            closeTable();
            html.push(`<h3>${inlineMarkdownPreview(row.slice(4))}</h3>`);
          } else if (row.startsWith('## ')) {
            closeList();
            closeTable();
            html.push(`<h2>${inlineMarkdownPreview(row.slice(3))}</h2>`);
          } else if (row.startsWith('# ')) {
            closeList();
            closeTable();
            html.push(`<h1>${inlineMarkdownPreview(row.slice(2))}</h1>`);
          } else if (row.startsWith('- ')) {
            if (!inList) {
              html.push('<ul>');
              inList = true;
            }
            html.push(`<li>${inlineMarkdownPreview(row.slice(2))}</li>`);
          } else {
            closeList();
            closeTable();
            html.push(`<p>${inlineMarkdownPreview(row)}</p>`);
          }
        }
        if (inCode) html.push(`<pre><code>${escapeHtml(codeRows.join('\n'))}</code></pre>`);
        closeList();
        closeTable();
        return html.join('\n');
      }

      function stableStringify(value) {
        return JSON.stringify(value ?? null);
      }

      function buildDiffSummary() {
        const articleBefore = new Map((savedSnapshot.articles || []).map((article) => [article.slug, article]));
        const articleAfter = new Map((state.articles || []).map((article) => [article.slug, article]));
        const projectBefore = new Map((savedSnapshot.projects || []).map((project) => [project.slug, project]));
        const projectAfter = new Map((state.projects || []).map((project) => [project.slug, project]));
        const added = [];
        const changed = [];
        const removed = [];
        const projectChanges = [];
        articleAfter.forEach((article, slug) => {
          if (!articleBefore.has(slug)) added.push(article.title || slug);
          else if (stableStringify(articleBefore.get(slug)) !== stableStringify(article)) changed.push(article.title || slug);
        });
        articleBefore.forEach((article, slug) => {
          if (!articleAfter.has(slug)) removed.push(article.title || slug);
        });
        projectAfter.forEach((project, slug) => {
          if (!projectBefore.has(slug)) projectChanges.push(`新增 ${project.name || slug}`);
          else if (stableStringify(projectBefore.get(slug)) !== stableStringify(project)) projectChanges.push(`修改 ${project.name || slug}`);
        });
        projectBefore.forEach((project, slug) => {
          if (!projectAfter.has(slug)) projectChanges.push(`删除 ${project.name || slug}`);
        });
        const settingsChanged = stableStringify(savedSnapshot.settings) !== stableStringify(state.settings);
        return { added, changed, removed, projectChanges, settingsChanged };
      }

      function confirmSaveDiff() {
        const diff = buildDiffSummary();
        const lines = [
          '保存前差异预览：',
          `新增文章：${diff.added.length ? diff.added.join('、') : '无'}`,
          `修改文章：${diff.changed.length ? diff.changed.join('、') : '无'}`,
          `删除文章：${diff.removed.length ? diff.removed.join('、') : '无'}`,
          `项目变化：${diff.projectChanges.length ? diff.projectChanges.join('、') : '无'}`,
          `站点设置：${diff.settingsChanged ? '有修改' : '无修改'}`,
          '',
          '确认后会写入 content 目录下的 Markdown 文件。'
        ];
        return confirm(lines.join('\n'));
      }

      function buildContentIssues() {
        const issues = [];
        const projectSlugs = new Set(state.projects.map((project) => project.slug));
        const articleSlugs = new Set();
        state.articles.forEach((article) => {
          if (articleSlugs.has(article.slug)) issues.push(`文章 slug 重复：${article.slug}`);
          articleSlugs.add(article.slug);
          if (!article.title) issues.push(`${article.slug || '未命名文章'} 缺少标题`);
          if (!article.excerpt) issues.push(`${article.title || article.slug} 缺少摘要`);
          if (!article.content) issues.push(`${article.title || article.slug} 正文为空`);
          if (!slugPattern.test(article.slug || '')) issues.push(`${article.title || '未命名文章'} slug 不合法`);
          if (article.projectSlug && !projectSlugs.has(article.projectSlug)) {
            issues.push(`${article.title || article.slug} 关联了不存在的项目：${article.projectSlug}`);
          }
          const imageMatches = String(article.content || '').matchAll(/!\[[^\]]*\]\(([^)]+)\)/g);
          for (const match of imageMatches) {
            const imagePath = match[1];
            if (!imagePath.startsWith('/') && !/^https?:\/\//i.test(imagePath)) {
              issues.push(`${article.title || article.slug} 使用了相对图片路径：${imagePath}`);
            }
          }
        });
        state.projects.forEach((project) => {
          if (!project.name) issues.push(`${project.slug || '未命名项目'} 缺少项目名称`);
          if (!project.summary) issues.push(`${project.name || project.slug} 缺少项目简介`);
        });
        return issues;
      }


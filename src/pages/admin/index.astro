  </style>

  <script>
    // @ts-nocheck
    const loginForm = document.querySelector('#loginForm');
    if (loginForm) {
      loginForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const message = document.querySelector('#loginMessage');
        const submitButton = loginForm.querySelector('button[type="submit"]');
        const password = new FormData(loginForm).get('password');
        submitButton.disabled = true;
        message.textContent = '正在登录...';
        try {
          const response = await fetch('/api/admin/login', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ password })
          });
          if (response.ok) location.reload();
          else {
            const result = await response.json().catch(() => ({}));
            message.textContent = result.error || '登录失败，请检查密码。';
          }
        } catch {
          message.textContent = '网络异常，请重试。';
        } finally {
          submitButton.disabled = false;
        }
      });
    }

    const studio = document.querySelector('#studio');
    if (studio) {
      let state = { settings: {}, projects: [], articles: [] };
      let projectIndex = 0;
      let articleIndex = 0;
      let isDirty = false;

      const qs = (selector) => document.querySelector(selector);
      const qsa = (selector) => Array.from(document.querySelectorAll(selector));
      const splitList = (value) => String(value || '').split(',').map((item) => item.trim()).filter(Boolean);
      const lines = (value) => String(value || '').split('\n').map((item) => item.trim()).filter(Boolean);
      const escapeHtml = (value) => String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
      const progressFromText = (value) => lines(value).map((row) => {
        const [label, rawValue] = row.split(':');
        const nextValue = Math.min(100, Math.max(0, Number(rawValue || 0) || 0));
        return { label: (label || '').trim(), value: nextValue };
      }).filter((item) => item.label);
      const progressToText = (items) => (items || []).map((item) => `${item.label}:${item.value}`).join('\n');

      function setDirty(value = true) {
        isDirty = value;
        const message = qs('#saveMessage');
        if (message && value) message.textContent = '有未保存更改。';
      }

      studio.addEventListener('input', () => setDirty(true));
      studio.addEventListener('change', () => setDirty(true));
      window.addEventListener('beforeunload', (event) => {
        if (!isDirty) return;
        event.preventDefault();
        event.returnValue = '';
      });

      function syncPreviewFrames(version = Date.now()) {
        const selectedProject = state.projects[projectIndex];
        const selectedArticle = state.articles[articleIndex];
        const projectUrl = selectedProject?.slug ? `/project/${encodeURIComponent(selectedProject.slug)}` : '/projects';
        const articleUrl = selectedArticle?.slug ? `/articles/${encodeURIComponent(selectedArticle.slug)}` : '/';
        const projectPreview = qs('#projectPreview');
        const articlePreview = qs('#articlePreview');
        const projectLink = qs('#projectPreviewLink');
        const articleLink = qs('#articlePreviewLink');

        if (projectPreview) projectPreview.src = `${projectUrl}?preview=${version}`;
        if (articlePreview) articlePreview.src = `${articleUrl}?preview=${version}`;
        if (projectLink) projectLink.href = projectUrl;
        if (articleLink) articleLink.href = articleUrl;

        qsa('.front-preview').forEach((frame) => {
          if (frame.id !== 'projectPreview' && frame.id !== 'articlePreview') {
            frame.src = `/?preview=${version}`;
          }
        });
      }

      function scalePreviewFrames() {
        const canvasWidth = 1200;
        qsa('.preview-viewport').forEach((viewport) => {
          const frame = viewport.querySelector('.front-preview');
          if (!frame) return;
          const scale = Math.min(1, viewport.clientWidth / canvasWidth);
          frame.style.width = `${canvasWidth}px`;
          frame.style.minWidth = `${canvasWidth}px`;
          frame.style.height = `${Math.max(900, viewport.clientHeight / Math.max(scale, 0.1))}px`;
          frame.style.transform = `scale(${scale})`;
        });
      }

      const previewResizeObserver = 'ResizeObserver' in window
        ? new ResizeObserver(scalePreviewFrames)
        : null;

      qsa('.preview-viewport').forEach((viewport) => previewResizeObserver?.observe(viewport));
      window.addEventListener('resize', scalePreviewFrames);

      function field(name, label, value = '', options = {}) {
        const full = options.full ? ' full' : '';
        const tone = options.tone ? ` ${options.tone}` : '';
        const size = options.size ? ` ${options.size}` : '';
        const inputClass = options.content ? ' class="content-textarea"' : '';
        const placeholder = options.placeholder ? ` placeholder="${escapeHtml(options.placeholder)}"` : '';
        const hint = options.hint ? `<small>${escapeHtml(options.hint)}</small>` : '';
        const rows = options.rows ? ` rows="${escapeHtml(options.rows)}"` : '';
        const type = options.inputType || 'text';
        if (options.type === 'textarea') {
          return `<label class="field-card${full}${tone}${size}" data-field="${escapeHtml(name)}"><span class="field-top"><span>${escapeHtml(label)}</span>${hint}</span><textarea name="${escapeHtml(name)}"${inputClass}${placeholder}${rows}>${escapeHtml(value)}</textarea></label>`;
        }
        if (options.type === 'select') {
          return `<label class="field-card${full}${tone}${size}" data-field="${escapeHtml(name)}"><span class="field-top"><span>${escapeHtml(label)}</span>${hint}</span><select name="${escapeHtml(name)}">${options.choices.map((choice) => `<option value="${escapeHtml(choice.value)}" ${choice.value === value ? 'selected' : ''}>${escapeHtml(choice.label)}</option>`).join('')}</select></label>`;
        }
        return `<label class="field-card${full}${tone}${size}" data-field="${escapeHtml(name)}"><span class="field-top"><span>${escapeHtml(label)}</span>${hint}</span><input type="${escapeHtml(type)}" name="${escapeHtml(name)}" value="${escapeHtml(value)}"${placeholder} /></label>`;
      }

      function editorBlock(kicker, title, body, accent = '') {
        return `
          <section class="content-editor-block ${accent}">
            <div class="content-editor-head">
              <span>${escapeHtml(kicker)}</span>
              <h3>${escapeHtml(title)}</h3>
            </div>
            <div class="content-editor-grid">${body}</div>
          </section>
        `;
      }

      function settingControl(name, label, value = '', options = {}) {
        const placeholder = options.placeholder ? ` placeholder="${escapeHtml(options.placeholder)}"` : '';
        const tone = options.tone ? ` ${options.tone}` : '';
        const type = options.inputType || 'text';
        if (options.type === 'textarea') {
          return `
            <label class="setting-control${tone}" data-field="${escapeHtml(name)}">
              <span>${escapeHtml(label)}</span>
              <textarea name="${escapeHtml(name)}"${placeholder}>${escapeHtml(value)}</textarea>
            </label>
          `;
        }

        return `
          <label class="setting-control${tone}" data-field="${escapeHtml(name)}">
            <span>${escapeHtml(label)}</span>
            <input type="${escapeHtml(type)}" name="${escapeHtml(name)}" value="${escapeHtml(value)}"${placeholder} />
          </label>
        `;
      }

      function renderSettings() {
        const s = state.settings;
        qs('#settingsForm').innerHTML = `
          <section class="settings-hero-editor">
            <div class="hero-avatar-editor">
              <span>头像标识</span>
              <input name="ownerInitial" value="${escapeHtml(s.ownerInitial)}" maxlength="2" />
            </div>
            <div class="hero-brand-editor">
              ${settingControl('siteTitle', '站点名称', s.siteTitle, { tone: 'brand-title-control', placeholder: 'CodePulse' })}
              <div class="brand-meta-grid">
                ${settingControl('siteSubtitle', '站点副标题', s.siteSubtitle, { tone: 'soft-pill-control', placeholder: '我的技术成长记录' })}
                ${settingControl('ownerName', '博主姓名', s.ownerName, { tone: 'soft-pill-control', placeholder: '你的名字' })}
              </div>
            </div>
          </section>

          <section class="settings-content-editor">
            <div class="identity-editor">
              ${settingControl('identity', '身份标签', s.identity, { tone: 'identity-control', placeholder: '2026 届本科毕业生 · Go / Java 双修' })}
            </div>
            <div class="status-editor">
              <div class="status-pulse"></div>
              ${settingControl('status', '状态播报', s.status, { type: 'textarea', tone: 'status-control', placeholder: '正在重构消息队列中间件...' })}
            </div>
            <div class="bio-editor">
              ${settingControl('bio', '博客简介', s.bio, { type: 'textarea', tone: 'bio-control', placeholder: '这里记录项目从想法、设计、实现到复盘的全过程...' })}
            </div>
          </section>

          <section class="settings-contact-editor">
            ${settingControl('github', 'GitHub', s.github, { inputType: 'url', tone: 'contact-control', placeholder: 'https://github.com/yourname' })}
            ${settingControl('email', '邮箱', s.email, { inputType: 'email', tone: 'contact-control', placeholder: 'hello@example.com' })}
            ${settingControl('location', '位置', s.location, { tone: 'contact-control', placeholder: 'China' })}
            ${settingControl('adminTitle', '后台标题', s.adminTitle, { tone: 'contact-control', placeholder: 'CodePulse Studio' })}
          </section>
        `;
      }

      function readSettings() {
        const form = new FormData(qs('#settingsForm'));
        state.settings = Object.fromEntries(form.entries());
      }

      function renderProjectList() {
        qs('#projectList').innerHTML = state.projects.map((project, index) => (
          `<button class="record-item ${index === projectIndex ? 'active' : ''}" type="button" data-project="${index}"><strong>${escapeHtml(project.name)}</strong><br><span>${escapeHtml(project.status)} · ${escapeHtml(project.slug)}</span></button>`
        )).join('');
        qsa('[data-project]').forEach((button) => button.addEventListener('click', () => {
          readProjectForm();
          projectIndex = Number(button.dataset.project);
          renderProjects();
        }));
      }

      function renderProjectForm() {
        const p = state.projects[projectIndex] || {};
        qs('#projectForm').innerHTML = `
          ${editorBlock('01', '项目名片', `
            ${field('name', '项目名称', p.name, { tone: 'project-title-field title-field', full: true, placeholder: '例如：个人博客系统' })}
            ${field('slug', '访问路径 Slug', p.slug, { tone: 'mono-field', placeholder: 'my-project' })}
            ${field('status', '生命周期', p.status, { type: 'select', choices: [{ value: 'ongoing', label: '进行中' }, { value: 'archived', label: '已归档' }] })}
            ${field('statusLabel', '状态徽章', p.statusLabel, { placeholder: '规划中 / 开发中 / 已上线' })}
            ${field('featured', '首页展示', String(Boolean(p.featured)), { type: 'select', choices: [{ value: 'true', label: '展示在首页' }, { value: 'false', label: '不展示' }] })}
          `, 'identity-block')}

          ${editorBlock('02', '技术与摘要', `
            ${field('tech', '技术栈', (p.tech || []).join(', '), { full: true, tone: 'tag-field', hint: '用逗号分隔' })}
            ${field('summary', '项目简介', p.summary, { type: 'textarea', full: true, size: 'area-md', rows: 5, placeholder: '写清楚它解决什么问题、当前做到什么程度。' })}
            ${field('releaseNote', '发布说明', p.releaseNote, { full: true, tone: 'release-field', placeholder: '例如：MVP 已完成 / 正在内测' })}
          `, 'summary-block')}

          ${editorBlock('03', '进展与架构', `
            ${field('progress', '进度清单', progressToText(p.progress), { type: 'textarea', full: true, size: 'area-lg', rows: 7, hint: '每行 label:value', placeholder: '需求设计:80\\n后端接口:60' })}
            ${field('monthUpdate', '近期进展', p.monthUpdate, { type: 'textarea', full: true, size: 'area-lg', rows: 7, placeholder: '记录最近一次关键进展、阻塞和下一步。' })}
            ${field('architecture', '架构流程', (p.architecture || []).join('\n'), { type: 'textarea', full: true, size: 'area-lg', rows: 7, hint: '每行一个节点', placeholder: '前端页面\\nAPI 服务\\n数据持久化' })}
          `, 'architecture-block')}

          <div class="form-actions"><button class="btn secondary" id="deleteProject" type="button">删除项目</button></div>
        `;
        qs('#deleteProject').addEventListener('click', () => {
          if (!confirm('确定删除当前项目？保存后才会真正写入。')) return;
          state.projects.splice(projectIndex, 1);
          projectIndex = Math.max(0, projectIndex - 1);
          setDirty(true);
          renderProjects();
        });
      }

      function readProjectForm() {
        const formEl = qs('#projectForm');
        if (!formEl || !state.projects[projectIndex]) return;
        const form = new FormData(formEl);
        state.projects[projectIndex] = {
          slug: form.get('slug'),
          name: form.get('name'),
          status: form.get('status'),
          statusLabel: form.get('statusLabel'),
          tech: splitList(form.get('tech')),
          summary: form.get('summary'),
          progress: progressFromText(form.get('progress')),
          monthUpdate: form.get('monthUpdate'),
          releaseNote: form.get('releaseNote'),
          architecture: lines(form.get('architecture')),
          featured: String(form.get('featured')).toLowerCase() === 'true'
        };
      }

      function renderProjects() {
        renderProjectList();
        renderProjectForm();
        syncPreviewFrames();
      }

      function renderArticleList() {
        qs('#articleList').innerHTML = state.articles.map((article, index) => (
          `<button class="record-item ${index === articleIndex ? 'active' : ''}" type="button" data-article="${index}"><strong>${escapeHtml(article.title)}</strong><br><span>${escapeHtml(article.kind)} · ${escapeHtml(article.date)}</span></button>`
        )).join('');
        qsa('[data-article]').forEach((button) => button.addEventListener('click', () => {
          readArticleForm();
          articleIndex = Number(button.dataset.article);
          renderArticles();
        }));
      }

      function renderArticleForm() {
        const a = state.articles[articleIndex] || {};
        qs('#articleForm').innerHTML = `
          ${editorBlock('01', '文章标题区', `
            ${field('title', '文章标题', a.title, { full: true, tone: 'article-title-field title-field', placeholder: '写一个清晰、有辨识度的标题' })}
            ${field('slug', '访问路径 Slug', a.slug, { tone: 'mono-field', placeholder: 'article-slug' })}
            ${field('date', '发布日期', a.date, { inputType: 'date' })}
          `, 'article-heading-block')}

          ${editorBlock('02', '归类与关联', `
            ${field('kind', '文章类型', a.kind, { type: 'select', choices: [
              { value: 'spec', label: '说明书' },
              { value: 'devlog', label: '开发日志' },
              { value: 'tool', label: '工具箱' },
              { value: 'interview', label: '面经' },
              { value: 'job', label: '求职心路' },
              { value: 'resume', label: '简历经验' },
              { value: 'essay', label: '随笔' }
            ] })}
            ${field('category', '分类', a.category)}
            ${field('projectSlug', '所属项目 Slug', a.projectSlug, { tone: 'mono-field' })}
            ${field('lifecycle', '生命周期', a.lifecycle, { type: 'select', choices: [{ value: '', label: '无' }, { value: 'ongoing', label: '进行中' }, { value: 'archived', label: '已归档' }] })}
            ${field('tags', '标签', (a.tags || []).join(', '), { full: true, tone: 'tag-field', hint: '用逗号分隔' })}
            ${field('company', '公司', a.company || '')}
            ${field('position', '岗位', a.position || '')}
          `, 'article-meta-block')}

          ${editorBlock('03', '正文写作区', `
            ${field('excerpt', '文章摘要', a.excerpt, { type: 'textarea', full: true, size: 'area-md', rows: 5, placeholder: '摘要会出现在列表和文章页头部。' })}
            ${field('content', '正文 Markdown', a.content, { type: 'textarea', full: true, content: true, size: 'area-xl', rows: 18, placeholder: '## 小标题\\n\\n开始写正文...' })}
          `, 'article-writing-block')}

          <div class="form-actions"><button class="btn secondary" id="deleteArticle" type="button">删除文章</button></div>
        `;
        qs('#deleteArticle').addEventListener('click', () => {
          if (!confirm('确定删除当前文章？保存后才会真正写入。')) return;
          state.articles.splice(articleIndex, 1);
          articleIndex = Math.max(0, articleIndex - 1);
          setDirty(true);
          renderArticles();
        });
      }

      function readArticleForm() {
        const formEl = qs('#articleForm');
        if (!formEl || !state.articles[articleIndex]) return;
        const form = new FormData(formEl);
        state.articles[articleIndex] = {
          slug: form.get('slug'),
          title: form.get('title'),
          date: form.get('date'),
          kind: form.get('kind'),
          category: form.get('category'),
          projectSlug: form.get('projectSlug'),
          lifecycle: form.get('lifecycle'),
          tags: splitList(form.get('tags')),
          company: form.get('company'),
          position: form.get('position'),
          excerpt: form.get('excerpt'),
          content: form.get('content')
        };
      }

      function renderArticles() {
        renderArticleList();
        renderArticleForm();
        syncPreviewFrames();
      }

      qsa('.studio-tab').forEach((button) => button.addEventListener('click', () => {
        qsa('.studio-tab').forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        qsa('[data-panel]').forEach((panel) => panel.classList.toggle('hidden', panel.dataset.panel !== button.dataset.tab));
        requestAnimationFrame(scalePreviewFrames);
      }));

      qs('#newProject').addEventListener('click', () => {
        readProjectForm();
        state.projects.unshift({
          slug: `new-project-${Date.now()}`,
          name: '新项目',
          status: 'ongoing',
          statusLabel: '规划中',
          tech: [],
          summary: '',
          progress: [],
          monthUpdate: '',
          releaseNote: '',
          architecture: [],
          featured: false
        });
        projectIndex = 0;
        setDirty(true);
        renderProjects();
      });

      qs('#newArticle').addEventListener('click', () => {
        readArticleForm();
        state.articles.unshift({
          slug: `new-article-${Date.now()}`,
          title: '新文章',
          date: new Date().toISOString().slice(0, 10),
          kind: 'devlog',
          category: '开发日志',
          projectSlug: '',
          lifecycle: '',
          tags: [],
          excerpt: '',
          content: '## 标题\n\n正文内容。'
        });
        articleIndex = 0;
        setDirty(true);
        renderArticles();
      });

      qs('#saveAll').addEventListener('click', async () => {
        readSettings();
        readProjectForm();
        readArticleForm();
        const saveButton = qs('#saveAll');
        saveButton.disabled = true;
        qs('#saveMessage').textContent = '正在保存...';
        try {
          const response = await fetch('/api/admin/content', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(state)
          });
          const result = await response.json().catch(() => ({}));
          if (response.ok) {
            setDirty(false);
            qs('#saveMessage').textContent = `已保存，前台已刷新。${new Date().toLocaleTimeString()}`;
            syncPreviewFrames(result.version?.version || Date.now());
            if ('BroadcastChannel' in window) {
              const channel = new BroadcastChannel('codepulse-content');
              channel.postMessage({ type: 'content-saved', savedAt: result.version?.version || Date.now() });
              channel.close();
            }
            try {
              localStorage.setItem('codepulse-content-saved', String(result.version?.version || Date.now()));
            } catch {}
          } else {
            const details = Array.isArray(result.details) ? `：${result.details.slice(0, 3).join('；')}` : '';
            qs('#saveMessage').textContent = `${result.error || '保存失败，请重试'}${details}`;
          }
        } catch {
          qs('#saveMessage').textContent = '保存失败，请检查网络或服务状态。';
        } finally {
          saveButton.disabled = false;
        }
      });

      qs('#logout').addEventListener('click', async () => {
        if (isDirty && !confirm('还有未保存更改，确定退出？')) return;
        await fetch('/api/admin/logout', { method: 'POST' });
        location.reload();
      });

      fetch('/api/admin/content')
        .then((response) => response.json())
        .then((data) => {
          state = data;
        renderSettings();
        renderProjects();
        renderArticles();
        syncPreviewFrames(data.version?.version || Date.now());
        scalePreviewFrames();
      });
    }
  </script>
</BaseLayout>

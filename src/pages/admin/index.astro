      qs('#articleImportFile').addEventListener('change', async (event) => {
        event.stopPropagation();
        const files = Array.from(event.target.files || []);
        if (!files.length) return;
        readArticleForm();
        if (files.length > 1) {
          const imported = [];
          const errors = [];
          for (const file of files) {
            try {
              const markdown = await file.text();
              const { article, hasFrontmatter } = parseArticleMarkdown(markdown, file.name);
              const nextErrors = validateImportedArticle(article, hasFrontmatter);
              if (nextErrors.length) errors.push(`${file.name}：${nextErrors.join('；')}`);
              else imported.push(article);
            } catch {
              errors.push(`${file.name}：读取失败，请确认文件是 UTF-8 编码。`);
            }
          }
          if (errors.length) {
            articleImportDraft = {
              article: { slug: '', title: '', date: today(), status: 'draft', kind: 'devlog', category: '开发日志', projectSlug: '', lifecycle: '', tags: [], company: '', position: '', excerpt: '', content: '' },
              fileName: '批量导入失败',
              existingIndex: -1,
              mode: 'new',
              errors
            };
            renderArticleImportPanel();
            return;
          }
          imported.reverse().forEach((article) => {
            article.slug = makeUniqueArticleSlug(article.slug);
            state.articles.unshift(article);
          });
          articleIndex = 0;
          articleImportDraft = null;
          setDirty(true);
          renderArticles();
          qs('#saveMessage').textContent = `已导入 ${imported.length} 篇文章，点击“保存全部”后写入 Markdown 文件。`;
          return;
        }

        const file = files[0];
        try {
          const markdown = await file.text();
          const { article, hasFrontmatter } = parseArticleMarkdown(markdown, file.name);
          const existingIndex = state.articles.findIndex((item) => item.slug === article.slug);
          articleImportDraft = {
            article,
            fileName: file.name,
            existingIndex,
            mode: existingIndex >= 0 ? 'replace' : 'new',
            errors: validateImportedArticle(article, hasFrontmatter)
          };
        } catch {
          articleImportDraft = {
            article: {
              slug: '',
              title: '',
              date: today(),
              status: 'draft',
              kind: 'devlog',
              category: '开发日志',
              projectSlug: '',
              lifecycle: '',
              tags: [],
              company: '',
              position: '',
              excerpt: '',
              content: ''
            },
            fileName: file.name,
            existingIndex: -1,
            mode: 'new',
            errors: ['读取文件失败，请确认文件是 UTF-8 编码的 Markdown。']
          };
        }
        renderArticleImportPanel();
      });

      qs('#exportProject').addEventListener('click', () => {
        readProjectForm();
        const project = state.projects[projectIndex];
        if (!project) return;
        downloadText(`${project.slug || 'project'}.md`, projectToMarkdown(project));
      });

      qs('#importProject').addEventListener('click', () => {
        const input = qs('#projectImportFile');
        input.value = '';
        input.click();
      });

      qs('#projectImportFile').addEventListener('change', async (event) => {
        const file = event.target.files?.[0];
        if (!file) return;
        readProjectForm();
        try {
          const project = parseProjectMarkdown(await file.text(), file.name);
          const index = state.projects.findIndex((item) => item.slug === project.slug);
          if (index >= 0 && confirm(`项目 ${project.slug} 已存在，是否覆盖？`)) {
            state.projects[index] = project;
            projectIndex = index;
          } else {
            state.projects.unshift(project);
            projectIndex = 0;
          }
          setDirty(true);
          renderProjects();
        } catch (error) {
          qs('#saveMessage').textContent = error.message || '项目导入失败。';
        }
      });

      qs('#exportSettings').addEventListener('click', () => {
        readSettings();
        downloadText('settings.md', settingsToMarkdown(state.settings));
      });

      qs('#importSettings').addEventListener('click', () => {
        const input = qs('#settingsImportFile');
        input.value = '';
        input.click();
      });

      qs('#settingsImportFile').addEventListener('change', async (event) => {
        const file = event.target.files?.[0];
        if (!file) return;
        try {
          state.settings = parseSettingsMarkdown(await file.text());
          setDirty(true);
          renderSettings();
        } catch (error) {
          qs('#saveMessage').textContent = error.message || '设置导入失败。';
        }
      });

      qs('#saveAll').addEventListener('click', async () => {
        readSettings();
        readProjectForm();
        readArticleForm();
        if (!confirmSaveDiff()) return;
        const saveButton = qs('#saveAll');
        saveButton.disabled = true;
        qs('#saveMessage').textContent = '正在保存...';
        try {
          const response = await fetch('/api/admin/content', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(state)
          });
          const result = await response.json().catch(() => ({}));
          if (response.ok) {
            savedSnapshot = JSON.parse(JSON.stringify(state));
            setDirty(false);
            qs('#saveMessage').textContent = `已保存，前台已刷新。${new Date().toLocaleTimeString()}`;
            syncPreviewFrames(result.version?.version || Date.now());
            if ('BroadcastChannel' in window) {
              const channel = new BroadcastChannel('codepulse-content');
              channel.postMessage({ type: 'content-saved', savedAt: result.version?.version || Date.now() });
              channel.close();
            }
            try {
              localStorage.setItem('codepulse-content-saved', String(result.version?.version || Date.now()));
            } catch {}
          } else {
            const details = Array.isArray(result.details) ? `：${result.details.slice(0, 3).join('；')}` : '';
            qs('#saveMessage').textContent = `${result.error || '保存失败，请重试'}${details}`;
          }
        } catch {
          qs('#saveMessage').textContent = '保存失败，请检查网络或服务状态。';
        } finally {
          saveButton.disabled = false;
        }
      });

      qs('#logout').addEventListener('click', async () => {
        if (isDirty && !confirm('还有未保存更改，确定退出？')) return;
        await fetch('/api/admin/logout', { method: 'POST' });
        location.reload();
      });

      fetch('/api/admin/content')
        .then((response) => response.json())
        .then((data) => {
          state = data;
        savedSnapshot = JSON.parse(JSON.stringify(data));
        renderSettings();
        renderProjects();
        renderArticles();
        syncPreviewFrames(data.version?.version || Date.now());
        scalePreviewFrames();
      });
    }
  </script>
</BaseLayout>
